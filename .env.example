# Self-hosted only: shared analytics sink for normalized dashboard facts.
# Do not use this for PhantomClaw Cloud. Managed storage should go through
# authenticated `phantomclaw-cli bundle sync`.
AUTOMATION_ANALYTICS_DATABASE_URL=postgresql://user:password@host/database

# LinkedIn company profile engagement automation.
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_SEARCH_URL=https://www.linkedin.com/search/results/content/?keywords=opportunities
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_PROFILE=work-profile
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_ACTOR=Example Company
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_POST_CAP=3
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_REPOST_CAP=1
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_COMMENT_CAP=12
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_MAX_PASSES=6
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_FOLLOW_CAP=25
# Self-hosted only: direct state/observation persistence.
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_DATABASE_URL=postgresql://user:password@host/database
# Self-hosted only: normalized analytics sink. This no longer defaults to the
# state database implicitly.
LINKEDIN_COMPANY_PROFILE_ENGAGEMENT_ANALYTICS_DATABASE_URL=postgresql://user:password@host/database

# LinkedIn Sales Community automation.
LINKEDIN_SALES_COMMUNITY_ENGAGEMENT_URL=https://scommunity.linkedin.com/
LINKEDIN_SALES_COMMUNITY_ENGAGEMENT_PROFILE=work-profile
LINKEDIN_SALES_COMMUNITY_ENGAGEMENT_LIKE_CAP=1
# Self-hosted only: normalized analytics sink.
LINKEDIN_SALES_COMMUNITY_ENGAGEMENT_ANALYTICS_DATABASE_URL=postgresql://user:password@host/database
